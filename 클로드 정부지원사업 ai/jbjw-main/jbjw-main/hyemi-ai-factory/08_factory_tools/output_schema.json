{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HyemiGrantFactory Output & State v1",
  "description": "공장 실행이 만들어내는 파일 목록과 프로젝트 상태 파일(project.json) 스키마",
  "type": "object",
  "definitions": {
    "stage_status": {
      "type": "string",
      "enum": ["PENDING", "DRAFT", "PENDING_APPROVAL", "BLOCKED", "REVIEWED", "LOCKED", "SKIPPED"],
      "description": "PENDING=미실행, DRAFT=생성됨(검수 전), PENDING_APPROVAL=사람 승인 대기, BLOCKED=탈락급 리스크로 중단, REVIEWED=검수 통과, LOCKED=사람 확정"
    }
  },
  "properties": {
    "project_state": {
      "description": "04_outputs/<project>/project.json 의 스키마",
      "type": "object",
      "required": ["project_name", "stages"],
      "properties": {
        "project_name": { "type": "string" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "is_sample": { "type": "boolean", "description": "true면 어떤 단계도 LOCKED 전환 금지 (D-006)" },
        "stages": {
          "type": "object",
          "properties": {
            "notice":   { "$ref": "#/definitions/stage_status" },
            "risk":     { "$ref": "#/definitions/stage_status" },
            "ideas":    { "$ref": "#/definitions/stage_status" },
            "lock":     { "$ref": "#/definitions/stage_status" },
            "review":   { "$ref": "#/definitions/stage_status" },
            "revision": { "$ref": "#/definitions/stage_status" },
            "handoff":  { "$ref": "#/definitions/stage_status" }
          }
        },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "blockers": { "type": "array", "items": { "type": "string" }, "description": "BLOCKED 사유. 비우려면 사람 확인 + approvals 갱신 필요" },
        "needs_confirmation": { "type": "array", "items": { "type": "string" }, "description": "[확인 필요] 항목 누적 목록" }
      }
    },
    "output_files": {
      "description": "단계별 생성 파일. ai_prompt_*.md 는 AI 판단이 필요한 단계에서 CLI가 만들어주는 '붙여넣기용 프롬프트'",
      "type": "object",
      "properties": {
        "notice":   { "const": ["04_outputs/<p>/notice_summary.md"] },
        "risk":     { "const": ["04_outputs/<p>/applicant_risk_check.md"] },
        "ideas":    { "const": ["04_outputs/<p>/idea_comparison_table.md", "04_outputs/<p>/ai_prompt_ideas.md"] },
        "lock":     { "const": ["04_outputs/<p>/selected_idea_lock.md", "04_outputs/<p>/ai_prompt_lock.md"] },
        "review":   { "const": ["05_reviews/<p>/review_scan_report.md", "05_reviews/<p>/ai_prompt_judge.md"] },
        "revision": { "const": ["05_reviews/<p>/revision_order_auto.md"] },
        "handoff":  { "const": ["10_handoff/HANDOFF_<p>.md"] }
      }
    }
  }
}
