    "월1회": 30,
    "격월": 60,
    "분기": 90,
    "반기": 180,
    "연1회": 365,
}
DEFAULT_CYCLE_DAYS = 90


def load_yaml(path):
    with open(path, encoding="utf-8") as f:
        return yaml.safe_load(f)


def load_json(path):
    with open(path, encoding="utf-8") as f:
        return json.load(f)


def _today():
    """[2026-07-07 신규] 오늘 날짜. 테스트 재현성을 위해 PEST_SKILL_TODAY 환경변수로
    override 가능(gov-support-matching-skill의 GOV_SKILL_TODAY 패턴과 동일)."""
    override = os.environ.get("PEST_SKILL_TODAY")
    if override:
        return date.fromisoformat(override)
    return date.today()


def build_graph(stages, triggers=None):
    """stage 간 실행 순서 그래프. depends_on 기반 엣지에 더해, [2026-07-07 (2단계)
    신규] entry_points로 선언된 대안 진입 경로도 엣지로 추가한다 — 예:
    방문알림봇.entry_points에 schedule:visit_cycle이 있고, schedule 트리거의
    entry_stage가 리마인더봇이면, '리마인더봇 -> 방문알림봇' 엣지를 추가해
    schedule 경로가 리마인더봇에서 멈추지 않고 이어지게 한다(card-08 해결).
    이 엣지는 depends_on 그래프를 대체하지 않고 '추가'만 한다(manifest.schema.v2.yaml
    entry_points 문서화 원칙 — depends_on은 주 경로만 유지)."""
    by_id = {s["id"]: s for s in stages}
    successors = {s["id"]: [] for s in stages}
    for s in stages:
        for dep in s.get("depends_on", []) or []:
            successors.setdefault(dep, []).append(s["id"])

    if triggers:
        trigger_entry_by_key = {}
        for t in triggers:
            ttype = t.get("type")
            ident = t.get("source") if ttype == "event" else t.get("interval") if ttype == "schedule" else None
            if ttype and ident:
                trigger_entry_by_key[f"{ttype}:{ident}"] = t.get("entry_stage")
        for s in stages:
            for ep in (s.get("entry_points") or []):
                origin = trigger_entry_by_key.get(ep)
                if not origin or origin == s["id"]:
                    continue
                successors.setdefault(origin, [])
                if s["id"] not in successors[origin]:
                    successors[origin].append(s["id"])

    return by_id, successors


def reachable_from(entry_id, successors):
    """entry_id에서 successors 방향을 따라 도달 가능한 stage id 목록(BFS 순서)"""
    seen = set()
    queue = [entry_id]
    order = []
    while queue:
        cur = queue.pop(0)
        if cur in seen:
            continue
        seen.add(cur)
        order.append(cur)
        for nxt in successors.get(cur, []):
            if nxt not in seen:
                queue.append(nxt)
    return order


def topo_order(stage_ids, by_id, successors):
    """stage_ids 부분집합만 대상으로 위상정렬.
    [2026-07-07 (2단계) 변경] 예전엔 이 함수가 각 stage의 depends_on을 다시 읽어
    엣지를 재구성했는데, 그러면 entry_points로 build_graph()가 추가해둔 대안
    엣지(예: 리마인더봇->방문알림봇)가 무시돼 schedule 경로에서 순서가 꼬였다
    (방문알림봇의 depends_on=[고객DB저장봇]이 스케줄 서브셋엔 없어 indegree
    0으로 오판됨). 이제는 build_graph()가 만든 successors(엣지의 단일 출처)를
    그대로 재사용해 위상정렬한다 — 그래프를 두 곳에서 따로 만들지 않음."""
    stage_id_set = set(stage_ids)
    indeg = {sid: 0 for sid in stage_ids}
    edges = {sid: [] for sid in stage_ids}
    for sid in stage_ids:
        for nxt in successors.get(sid, []):
            if nxt in stage_id_set:
                edges[sid].append(nxt)
                indeg[nxt] += 1
    queue = [sid for sid in stage_ids if indeg[sid] == 0]
    order = []
    while queue:
        cur = queue.pop(0)
        order.append(cur)
        for nxt in edges[cur]:
            indeg[nxt] -= 1
            if indeg[nxt] == 0:
                queue.append(nxt)
    if len(order) != len(stage_ids):
        missing = stage_id_set - set(order)
        raise RuntimeError(f"위상정렬 실패 — 순환 의존성 의심: {missing}")
    return order


def evaluate_run_if(condition, ctx):
    """v2 스키마: run_if는 형식 파서가 없는 단순 조건 식별자/문자열이다(manifest.schema.v2.yaml 참고).
    여기서는 알려진 조건만 실제로 평가하고, 나머지는 안전하게 False(건너뜀)로 처리한다."""
    if condition is None:
        return True, "run_if 없음 — 항상 실행"
    if condition == "미정_골든셋수집후결정":
        return False, "미정 상태 — 골든셋 확보 전까지 기본 꺼짐(사용자 지시, 2026-07-07)"
    if condition == "완료보고서_또는_소독증명서를_요청함":
        # [2026-07-07 (2단계) 신규 — 3단계 테스트 갭1 해결] document_requested
        # 단일 boolean을 report_requested/certificate_requested로 분리한 데
        # 맞춰 run_if 조건도 갱신.
        cr = ctx.get("customer_record") or {}
        wants_report = bool(cr.get("report_requested") if "report_requested" in cr else ctx.get("report_requested"))
        wants_cert = bool(cr.get("certificate_requested") if "certificate_requested" in cr else ctx.get("certificate_requested"))
        return (wants_report or wants_cert), f"customer_record.report_requested={wants_report}, certificate_requested={wants_cert}"
    if condition == "고객이_문서를_요청함":
        # [구버전 호환] document_requested 단일 boolean 시대의 조건 식별자.
        # manifest는 이제 위 새 식별자를 쓰지만, 예전 입력/테스트 호환을 위해 남겨둠.
        cr = ctx.get("customer_record") or {}
        wants_doc = bool(cr.get("document_requested") or ctx.get("document_requested"))
        return wants_doc, f"[구버전 조건] customer_record.document_requested={wants_doc}"
    return False, f"알 수 없는 run_if 조건 '{condition}' — 안전하게 기본값 False(건너뜀) 처리"


