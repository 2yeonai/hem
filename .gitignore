.obsidian/bookmarks.json

# Obsidian 캐시 및 임시 파일
.obsidian/cache/
.obsidian/workspace.json.bak

# 플러그인 개인 데이터 (플러그인 소스는 포함, 개인 설정만 제외)
.obsidian/plugins/*/data.json

# Obsidian 휴지통
.trash/

# macOS 시스템 파일
.DS_Store
.AppleDouble
.LSOverride

# Windows 시스템 파일
