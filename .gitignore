# Obsidian 개인 설정 파일 (팀과 공유하지 않을 파일들)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/hotkeys.json
.obsidian/app.json
.obsidian/appearance.json
.obsidian/bookmarks.json

# Obsidian 캐시 및 임시 파일
.obsidian/cache/
.obsidian/workspace.json.bak

# 플러그인 개인 데이터 (플러그인 소스는 포함, 개인 설정만 제외)
.obsidian/plugins/*/data.json

# Obsidian 휴지통
.trash/

# macOS 시스템 파일
.DS_Store
.AppleDouble
.LSOverride

# Windows 시스템 파일
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini

# 원본 강의 녹취 오디오/비디오 (2026-07-16 추가) — 1.2GB, git add -A가 이 폴더 때문에
# FUSE 마운트에서 타임아웃남. 변환된 텍스트본(_원문.md 등)은 그대로 커밋 대상.
1. Projects/강사방법론/강의녹취_원문/*.m4a
1. Projects/강사방법론/강의녹취_원문/*.mp4

# git이 만드는 잠금파일이 이 마운트에서 삭제가 안 돼 .stale-*로 남는 경우가 있음(알려진 환경 이슈)
.git/*.lock.stale-*
.git/*.lock.bak

# Linux 시스템 파일
*~
.directory

# 백업 파일
*.bak
*.tmp
*.temp

# 로그 파일
*.log

# 환경 변수 파일 (민감 정보 보호)
.env
.env.local
.env.*.local

# Node.js (플러그인 개발 시)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Git LFS (대용량 파일 관리 시)
# 필요하면 활성화: *.pdf, *.mp4, *.zip 등

# Claude Code 로컬 전용 설정/캐시 (기기별, 공유 안 함)
.claude/

# Claude Code 세션/플러그인 캐시 부산물 (vault 콘텐츠 아님, 실수로 생성됨 - .audit-key 등 민감 데이터 포함 가능)
# 2026-07-13 리오르그로 "1. Projects/" 하위로 이동됨 - 경로 갱신
1. Projects/*/66ae7e14-bf57-4b90-8273-697998213497/
1. Projects/*/833bf976-d4ba-4cef-b499-90407a612c9e/
1. Projects/*/rpm/
1. Projects/*/skills-plugin/

# Python 가상환경/캐시 (실수로 vault 안에 생성됨, 용량 큼 - 절대 커밋하지 않음)
.venv/
__pycache__/
*.pyc
