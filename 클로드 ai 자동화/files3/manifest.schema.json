{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Factory Skill Manifest",
  "description": "모든 공장(스킬)이 반드시 지켜야 하는 최소 계약. 이 스키마를 통과 못하면 2번 범용 제작기가 이 스킬을 읽을 수 없다.",
  "type": "object",
  "required": ["name", "version", "io_contract", "model_routing", "quality_gate", "invocation"],
  "properties": {
    "name": {
      "type": "string",
      "description": "스킬 식별자, 예: gov-support-app-skill"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "domain": {
      "type": "string",
      "enum": ["company_charter", "gov_support", "flower_shop", "pest_control", "content_repurpose", "generic"],
      "description": "3개 우선순위 도메인 + 콘텐츠 + 향후 확장을 위한 generic"
    },

    "io_contract": {
      "type": "object",
      "description": "공장의 진짜 정체성. 내부 구현이 바뀌어도 이건 안 바뀌어야 함",
      "required": ["input_schema", "output_schema"],
      "properties": {
        "input_schema": { "type": "object" },
        "output_schema": { "type": "object" }
      }
    },

    "model_routing": {
      "type": "object",
      "description": "모델명 절대 금지 (예: 'claude-fable-5' 같은 문자열 쓰면 안 됨). 티어 이름만 허용.",
      "required": ["stages"],
      "properties": {
        "stages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["step", "tier"],
            "properties": {
              "step": { "type": "string" },
              "tier": {
                "type": "string",
                "enum": ["low_cost", "mid", "high", "escalation"],
                "description": "low_cost=Haiku급, mid=Sonnet급, high=Opus급, escalation=Fable급(승격 전용, 최소사용)"
              }
            }
          }
        }
      }
    },

    "quality_gate": {
      "type": "object",
      "description": "도메인별로 반드시 파라미터화. boolean으로 두면 안 됨 (blind_spot #1)",
      "required": ["confidence_threshold", "on_fail"],
      "properties": {
        "confidence_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "고위험 도메인(예: 정부지원/방역)은 높게, 저위험(꽃집)은 낮게"
        },
        "self_check_rules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "on_fail": {
          "type": "object",
          "required": ["retry_count", "escalation_target"],
          "properties": {
            "retry_count": { "type": "integer", "minimum": 0 },
            "escalation_target": {
              "type": "string",
              "enum": ["self_retry", "human_review", "escalation_tier"],
              "description": "human_review일 경우 channel은 추상 이벤트로만 정의 (stop_rule #5)"
            }
          }
        }
      }
    },

    "invocation": {
      "type": "object",
      "description": "AI직원 플랫폼이 이 스킬을 tool로 호출할 때 쓰는 계약",
      "required": ["entrypoint", "callable_by"],
      "properties": {
        "entrypoint": { "type": "string", "description": "예: scripts/run.py 또는 scripts/run.sh" },
        "callable_by": {
          "type": "array",
          "items": { "type": "string" },
          "description": "예: ['ai_employee_platform', 'manual_cli']"
        }
      }
    },

    "state": {
      "type": "object",
      "description": "blind_spot #2: 상태는 스킬 내부에 두지 말고 외부 참조만",
      "properties": {
        "external_store_ref": {
          "type": "string",
          "description": "스킬 자체는 stateless. 실제 데이터 위치(DB/파일경로 등)를 여기 참조로만 명시"
        }
      }
    },

    "failure_log_format": {
      "type": "object",
      "description": "blind_spot #4: Fable 없이도 Sonnet/Codex가 디버깅할 수 있게 실패 로그 포맷 고정",
      "properties": {
        "fields": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["timestamp", "step", "input_summary", "error", "confidence_at_failure"]
        }
      }
    }
  }
}
