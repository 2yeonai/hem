{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HyemiGrantFactory Input v1",
  "description": "새 공고 프로젝트의 입력 스키마. 값이 없으면 null 대신 문자열 \"미확보\"를 넣는다 — 공장이 [확인 필요]로 처리한다.",
  "type": "object",
  "required": ["project_name", "notice", "applicant", "ideas"],
  "properties": {
    "project_name": { "type": "string", "description": "폴더명으로 쓸 프로젝트명 (영문·숫자·하이픈 권장)" },
    "created_at": { "type": "string", "description": "YYYY-MM-DD" },
    "notice": {
      "type": "object",
      "required": ["title", "raw_text"],
      "properties": {
        "title": { "type": "string" },
        "agency": { "type": "string" },
        "purpose": { "type": "string", "description": "공고 목적 (원문 표현 그대로)" },
        "raw_text": { "type": "string", "description": "공고문 원문 전체. '미확보'면 전 산출물이 [확인 필요] 모드가 된다" },
        "apply_deadline": { "type": "string" },
        "execution_period": { "type": "string", "description": "수행기간 (예: 협약 후 6개월)" },
        "eligibility": { "type": "string", "description": "신청자격 원문" },
        "exclusions": { "type": "string", "description": "지원제외 조건 원문 — 가장 중요" },
        "budget": {
          "type": "object",
          "properties": {
            "max_amount": { "type": ["number", "string"] },
            "self_pay_ratio": { "type": ["number", "string"] },
            "allowed_items": { "type": "array", "items": { "type": "string" } },
            "excluded_items": { "type": "array", "items": { "type": "string" } }
          }
        },
        "format": {
          "type": "object",
          "properties": {
            "form_type": { "type": "string", "description": "예: PSST, 자유양식" },
            "page_limit": { "type": ["number", "string"] },
            "char_limit": { "type": ["number", "string"] }
          }
        },
        "scoring": {
          "type": "array",
          "description": "심사표. 비어 있으면 evaluation_rubric.md 내부 기준으로 대체하고 [확인 필요] 표시",
          "items": {
            "type": "object",
            "required": ["item", "points"],
            "properties": {
              "item": { "type": "string" },
              "points": { "type": "number" },
              "note": { "type": "string" }
            }
          }
        },
        "presentation": {
          "type": "object",
          "properties": {
            "required": { "type": ["boolean", "string"] },
            "present_minutes": { "type": ["number", "string"] },
            "qna_minutes": { "type": ["number", "string"] }
          }
        },
        "bonus_items": { "type": "array", "items": { "type": "string" } }
      }
    },
    "applicant": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "biz_type": { "type": "string", "description": "예비창업자/개인/법인/팀" },
        "biz_years": { "type": ["number", "string"] },
        "industry": { "type": "string" },
        "industry_code": { "type": "string", "description": "업종코드 — 지원제외 대조용" },
        "channels": { "type": "array", "items": { "type": "string" } },
        "duplicate_grant_history": { "type": ["boolean", "string"], "description": "동일사업 중복수혜 여부. true면 STOP. '미확인'이면 승인 지점" },
        "tax_arrears": { "type": ["boolean", "string"], "description": "체납 여부. true면 STOP" },
        "closed_biz_history": { "type": ["boolean", "string"] },
        "notes": { "type": "string" }
      }
    },
    "ideas": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "name", "problem"],
        "properties": {
          "id": { "type": "string", "description": "예: idea1" },
          "name": { "type": "string" },
          "problem": { "type": "string", "description": "해결하는 문제 (시간·비용·오류로 구체화)" },
          "target": { "type": "string", "description": "고객 또는 수혜자" },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "budget_estimate": { "type": "string" },
          "evidence_owned": { "type": "array", "items": { "type": "string" } },
          "evidence_planned": { "type": "array", "items": { "type": "string" } },
          "risks": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "evidence": {
      "type": "object",
      "properties": {
        "owned": { "type": "array", "items": { "type": "string" }, "description": "실물로 존재 확인된 것만" },
        "planned": { "type": "array", "items": { "type": "string" } }
      }
    },
    "budget_plan": {
      "type": "array",
      "description": "예산 계획. 비어 있으면 예산 판정 불가 경고",
      "items": {
        "type": "object",
        "properties": {
          "item": { "type": "string" },
          "amount": { "type": ["number", "string"] },
          "purpose": { "type": "string" },
          "output": { "type": "string", "description": "이 돈을 쓰면 남는 산출물" }
        }
      }
    },
    "selected_idea_id": {
      "type": ["string", "null"],
      "description": "사람이 최종 확정한 아이디어 id. 비어 있으면 lock 단계에서 PENDING_APPROVAL로 중단"
    },
    "approvals": {
      "type": "object",
      "description": "사람 승인 기록. human_approval_points.md의 승인 지점과 1:1",
      "properties": {
        "eligibility_confirmed": { "type": "boolean", "description": "자격 3종(중복수혜·체납·업종코드) 서류 확인 완료" },
        "idea_selected": { "type": "boolean" },
        "budget_confirmed": { "type": "boolean" },
        "final_submission_approved": { "type": "boolean" }
      }
    }
  }
}
